// For format details, see https://aka.ms/devcontainer.json.
{
  "name": "Flutter",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {},
    "ghcr.io/postfinance/devcontainer-features/git-lfs:1": {},
    "ghcr.io/guiyomh/features/just:0": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "runArgs": [
    "--privileged",
    "-v", "/dev/bus/usb:/dev/bus/usb"
  ],
  "mounts": [
    "source=claude-config,target=/home/vscode/.claude,type=volume",
    "source=pacestrip-pub-cache,target=/home/vscode/.pub-cache,type=volume"
  ],
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.claude /home/vscode/.pub-cache"
}
